# Warisly web — environment contract.
# Public (NEXT_PUBLIC_*) values ship to the browser; everything else is server-only.
# The server keys below are validated at boot by src/lib/env.server.ts (Zod) — a missing
# one throws on startup, so keep this file in sync with that schema.

# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # client-side, RLS-bound
SUPABASE_SERVICE_ROLE_KEY=            # server-only; bypasses RLS — never in a client bundle

# ── WhatsApp Cloud API (intake webhook) ─────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=                # webhook verification handshake
WHATSAPP_APP_SECRET=                  # Meta app secret — webhook signature verification
WHATSAPP_ACCESS_TOKEN=                # Meta/BSP send token

# ── LLM (vision OCR + structuring + STT) ────────────────────────────────────
# Used by src/lib/llm.ts for asset extraction AND KTP OCR (gpt-4o vision). One provider.
OPENAI_API_KEY=

# ── eKYC (Dukcapil-licensed vendor: Privy / VIDA / Verihubs) ────────────────
EKYC_BASE_URL=
EKYC_API_KEY=
EKYC_WEBHOOK_SECRET=                  # HMAC secret for the verification callback

# ── Dev login bypass (POC ONLY — never set these on a production deployment) ──
# Lets the team into the owner app from /masuk without an SMS. A Vercel
# production deployment (VERCEL_ENV=production) hard-blocks it regardless. Sign-in
# uses the anon client — no service-role key in the request path. Seed the dev
# user once:  pnpm --filter @warisly/db seed:dev-user +6281234567890
DEV_LOGIN_BYPASS=                     # server-only; set to "1" to enable the bypass
DEV_LOGIN_PASSWORD=                   # server-only; shared password for seeded dev user(s)
NEXT_PUBLIC_DEV_LOGIN=                # set to "1" to render the dev forms on /masuk
NEXT_PUBLIC_DEV_LOGIN_PHONE=          # optional; pre-fills this number on the form
